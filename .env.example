# Supabase (from Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_DB_URL=postgresql://postgres:postgres@localhost:54322/postgres
# Remote migrations (Dashboard → Project Settings → Database → Database password)
# Required when `npx supabase db push` returns 403 login-role errors.
SUPABASE_DB_PASSWORD=

# LLM Providers (for METHOD MOIRAI)
OPENAI_API_KEY=
GOOGLE_AI_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# Inngest (async pipelines)
INNGEST_EVENT_KEY=

NEXT_PUBLIC_APP_ENV=local

# Public site URL (defaults to https://wivviw.com in metadata if unset). Use for preview/staging.
# Production hostnames: https://wivviw.com (primary), https://wivviw.app (alias).
# NEXT_PUBLIC_APP_URL=https://wivviw.com

# Private preview (production/staging): set a strong password so only you (or people you share it with)
# can open the app. Crawlers get noindex + robots disallow. Leave unset for local open dev.
# SITE_ACCESS_USER=preview
# SITE_ACCESS_PASSWORD=

# Optional: restrict who can use the app when Supabase Auth is configured (comma-separated emails).
# Empty = any authenticated user. In Supabase → Auth → URL config, add redirect URLs, e.g.:
#   http://localhost:3000/auth/callback
#   https://wivviw.com/auth/callback
#   https://wivviw.app/auth/callback
#
# Email confirmation links: default Supabase emails use PKCE (?code=) and only work in the same browser
# as signup. For links that work in any app/browser, edit Auth → Email Templates → “Confirm sign up”
# and replace the link with (type=email matches Supabase’s default verify flow for email confirmation):
#   <a href="{{ .RedirectTo }}?token_hash={{ .TokenHash }}&type=email">Confirm your email</a>
# Redirect URLs must include the exact {{ .RedirectTo }} origin you pass as emailRedirectTo (e.g. .../auth/callback).
# AUTH_ALLOWED_EMAILS=you@example.com,cofounder@example.com
